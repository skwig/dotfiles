! =================
! urxvt
! =================

! 
URxvt.font: 7x14
URxvt.boldFont:
URxvt.letterSpace: 0
URxvt.scrollBar: false

! copy & paste
URxvt.keysym.Shift-Control-C: eval:selection_to_clipboard
URxvt.keysym.Shift-Control-V: eval:paste_clipboard

! disable useless ctrl+shift ISO14755 mode
URxvt.iso14755: false
URxvt.iso14755_52: false

! =================
! rofi color scheme
! =================
#define hl_text #1F1F1F
#define m_color #ffb52a

rofi.color-enabled:		true
rofi.separator-style: 	solid
rofi.color-normal:		argb:00000000, #a89984, argb:00000000,  m_color,  hl_text
rofi.color-urgent:		argb:00000000, #F99157, argb:00000000,  #F99157,  hl_text
rofi.color-active:		argb:00000000, #6699CC, argb:00000000,  #6699CC,  hl_text
rofi.color-window:		argb:ee222222, m_color, m_color
rofi.font: Roboto regular 12
rofi.bw:                0
rofi.padding:           10
rofi.hide-scrollbar:    true
rofi.lines:             6

! ============
!   Couleurs
! ============
!*background: #1F1F1F
*background: #2E343E
*foreground: #ccd0d9
*secondary:  #535172
*active:     #259E83
!black
*color0:     #434a54
*color8:     #656d7a
!red
*color1:     #db4453
*color9:     #ec5662
!green
*color2:     #8cc051
*color10:    #a0d468
!yellow
*color3:     #f6bb43
*color11:    #ffce55
!blue
*color4:     #4b89dc
*color12:    #5d9cec
!magenta
*color5:     #967bdc
*color13:    #ac92ed
!cyan
*color6:     #36bc9b
*color14:    #48cfae
!white
*color7:     #f6f7fb
*color15:    #e6e9ee
